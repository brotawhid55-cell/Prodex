# TRODEX CONFIGURATION ENVIRONMENT TEMPLATE
# Copy these keys into your local development .env file if running locally.

# JWT Secret Key for Session Authentication Tokens
JWT_SECRET=your_jwt_secret_key_here

# Neon PostgreSQL Database Connection String (Optional, falls back to local JSON db if omitted)
DATABASE_URL=postgres://user:password@hostname/dbname?sslmode=require

# Google Gemini API Key for AI features (Optional)
GEMINI_API_KEY=your_gemini_api_key_here

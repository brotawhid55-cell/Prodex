# ================================
# TRODEX - Environment Variables
# ================================
# Copy this file to .env.local for local dev
# Add all these to Vercel → Settings → 
# Environment Variables for production

# DATABASE (Required - get from neon.tech)
# Go to neon.tech → New Project → 
# Connection String → copy pooled connection
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# AUTH SECRET (Required)
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=your_random_32_char_secret_here

# APP URL (Required)
# Local: http://localhost:3000
# Production: https://trodex.vercel.app
NEXTAUTH_URL=https://trodex.vercel.app

# JWT SECRET (Required - same as NEXTAUTH_SECRET)
JWT_SECRET=your_random_32_char_secret_here
